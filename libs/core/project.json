{
    "name": "core",
    "$schema": "../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/core/src",
    "prefix": "lib",
    "projectType": "library",
    "tags": [
        "core"
    ],
    "targets": {
        "build": {
            "executor": "@nx/angular:ng-packagr-lite",
            "outputs": [
                "{workspaceRoot}/dist/{projectRoot}"
            ],
            "options": {
                "project": "libs/core/ng-package.json"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}